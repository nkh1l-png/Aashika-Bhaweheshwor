# Copy this file to ".env" for local use, or set these as Environment Variables
# in your host (Render, etc.). NONE are required to run locally with db.json.

# --- Database (optional) ---
# If set, the app stores all data in MongoDB Atlas instead of the local db.json file.
# Get this from MongoDB Atlas: Database > Connect > Drivers > copy the connection string.
# Replace <password> with your real DB user password.
# MONGODB_URI=mongodb+srv://USER:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
# MONGODB_DB=stockflow

# --- Session secret (optional but recommended in production) ---
# Used to sign login tokens. If not set, the app generates one and stores it.
# Set a long random value in production so tokens stay valid across restarts.
# SESSION_SECRET=change-me-to-a-long-random-string

# --- Port (optional) ---
# Hosts like Render set this automatically. Defaults to 3000 locally.
# PORT=3000
